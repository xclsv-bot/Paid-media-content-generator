# ──────────────────────────────────────────────────────────────────────────
# Supabase — create a project at https://supabase.com, then Project Settings
# ──────────────────────────────────────────────────────────────────────────

# Settings -> API -> Project URL
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co

# Settings -> API -> Project API keys -> anon / public
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Settings -> API -> Project API keys -> service_role (SERVER ONLY — never ship to browser)
# Used by API routes to mint signed upload/download URLs and bypass RLS for trusted ops.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Storage bucket name for creative videos (created by migration 0002_storage.sql)
SUPABASE_VIDEO_BUCKET=creative-videos
# Same bucket name, exposed to the browser for the direct signed upload.
NEXT_PUBLIC_SUPABASE_VIDEO_BUCKET=creative-videos
# Reference-materials bucket (PDFs, example clips, screenshots).
SUPABASE_REFERENCES_BUCKET=references
NEXT_PUBLIC_SUPABASE_REFERENCES_BUCKET=references

# Default CPA/CPT target in dollars — the Performance Standard gate. The client's
# target is $30.00 (revisable monthly). Per-creative override lives in
# creatives.cpt_target_cents. Blank falls back to $30 in code.
# (Performance comes from the team's weekly report, not the Meta API.)
CPA_TARGET=30

# ──────────────────────────────────────────────────────────────────────────
# Script-generating agent — secret the external agent presents to push scripts
# via POST /api/agent/scripts (Authorization: Bearer <AGENT_API_KEY>).
# Generate a long random string; leave blank to disable the endpoint.
# ──────────────────────────────────────────────────────────────────────────
AGENT_API_KEY=

# ──────────────────────────────────────────────────────────────────────────
# Anthropic credentials for the Ideate workspace (AI concept brainstorming).
# The SDK resolves, in order: ANTHROPIC_API_KEY → ANTHROPIC_AUTH_TOKEN →
# Workload Identity Federation → a local `ant auth login` profile on disk.
#   • Deployed (Vercel/serverless): set ANTHROPIC_API_KEY here (get one at
#     https://console.anthropic.com) — there's no persistent CLI profile there.
#   • Local dev: leave blank and run `ant auth login` instead.
# Ideate stays disabled (clear 503) until one of these is available.
# ──────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ──────────────────────────────────────────────────────────────────────────
# OpenAI Whisper — transcribes each uploaded video (what was actually said) for
# hook-level analysis. Get a key at https://platform.openai.com/api-keys.
# Unset = uploads simply skip transcription (no error); staff can trigger it
# later from the video card once a key is set.
# ──────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ──────────────────────────────────────────────────────────────────────────
# Learning loop — minimum trials behind a creative before it counts toward the
# learnings scoreboard (avoids small-sample noise). Defaults to 20.
# ──────────────────────────────────────────────────────────────────────────
LOOP_MIN_TRIALS=20

# Fraction of matured creatives a family must hit to count as "proven" (0-1). Default 0.5.
LOOP_PROVEN_HIT_RATE=0.5

# ──────────────────────────────────────────────────────────────────────────
# Weekly heartbeat (vercel.json cron → GET /api/cron/loop): pulls Meta insights
# then regenerates learnings. Set CRON_SECRET to a long random string; Vercel
# sends it as `Authorization: Bearer <CRON_SECRET>` on scheduled runs. Unset =
# the endpoint is disabled (503).
# ──────────────────────────────────────────────────────────────────────────
CRON_SECRET=

# ──────────────────────────────────────────────────────────────────────────
# Winners Cache — the volume bar a creative must clear (on top of being a Hit,
# CPT <= target) before it's cached as "proven content".
# ──────────────────────────────────────────────────────────────────────────
WINNER_MIN_RESULTS=10        # minimum conversions
WINNER_MIN_SPEND_CENTS=5000  # minimum spend in cents ($50)

# Vercel Cron secret: Vercel attaches `Authorization: Bearer <CRON_SECRET>` to
# the scheduled GET /api/winners/refresh in vercel.json.
CRON_SECRET=
