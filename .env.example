# ──────────────────────────────────────────────────────────────────────────
# Supabase — create a project at https://supabase.com, then Project Settings
# ──────────────────────────────────────────────────────────────────────────

# Settings -> API -> Project URL
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co

# Settings -> API -> Project API keys -> anon / public
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Settings -> API -> Project API keys -> service_role (SERVER ONLY — never ship to browser)
# Used by API routes to mint signed upload/download URLs and bypass RLS for trusted ops.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Storage bucket name for creative videos (created by migration 0002_storage.sql)
SUPABASE_VIDEO_BUCKET=creative-videos
# Same bucket name, exposed to the browser for the direct signed upload.
NEXT_PUBLIC_SUPABASE_VIDEO_BUCKET=creative-videos
# Reference-materials bucket (PDFs, example clips, screenshots).
SUPABASE_REFERENCES_BUCKET=references
NEXT_PUBLIC_SUPABASE_REFERENCES_BUCKET=references

# ──────────────────────────────────────────────────────────────────────────
# Meta Marketing API (Phase 3 — leave blank until partner access + app review)
# ──────────────────────────────────────────────────────────────────────────
META_SYSTEM_USER_TOKEN=
META_AD_ACCOUNT_ID=
META_API_VERSION=v21.0

# Default CPT (cost-per-trial) target in dollars — the contract's Performance
# Standard gate. Outlier Target CPT is $30.00 (revisable monthly). Per-creative
# override lives in creatives.cpt_target_cents. Blank falls back to $30 in code.
META_CPT_TARGET=30

# ──────────────────────────────────────────────────────────────────────────
# Script-generating agent — secret the external agent presents to push scripts
# via POST /api/agent/scripts (Authorization: Bearer <AGENT_API_KEY>).
# Generate a long random string; leave blank to disable the endpoint.
# ──────────────────────────────────────────────────────────────────────────
AGENT_API_KEY=

# ──────────────────────────────────────────────────────────────────────────
# Anthropic credentials for the Ideate workspace (AI concept brainstorming).
# The SDK resolves, in order: ANTHROPIC_API_KEY → ANTHROPIC_AUTH_TOKEN →
# Workload Identity Federation → a local `ant auth login` profile on disk.
#   • Deployed (Vercel/serverless): set ANTHROPIC_API_KEY here (get one at
#     https://console.anthropic.com) — there's no persistent CLI profile there.
#   • Local dev: leave blank and run `ant auth login` instead.
# Ideate stays disabled (clear 503) until one of these is available.
# ──────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
